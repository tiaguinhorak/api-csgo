# =============================================================================
# Clutch LOCAL DEV — copy to .env and edit paths
# CS:GO in WSL: run api-csgo inside WSL too (simplest RCON + SQLite paths)
# =============================================================================

SERVER_PROFILE=warmup
SERVER_NAME=Clutch Local
SERVER_MODE_LABEL=Warmup Dev
CSGO_SERVER_POOL=warmup
WARMUP_VPS=1

PORT=3001
BIND_HOST=127.0.0.1
DATA_DIR=./data

# Same key as site/.env
CSGO_SKINS_SYNC_KEY=clutch-dev-skins-sync-2026
API_KEY=suachaveapi

# Site local (Next.js npm run dev)
CLUTCH_SITE_URL=http://127.0.0.1:3000
SITE_ORIGIN=http://127.0.0.1:3000

# --- CS:GO (WSL default paths) ---
CSGO_SERVER_DIR=/home/csgo/server
CSGO_SERVER_HOST=127.0.0.1
CSGO_PUBLIC_HOST=127.0.0.1
CSGO_RCON_PORT=27015
CSGO_RCON_PASSWORD=clutchclube
CSGO_RCON_LOOPBACK=1
CLUTCH_CS_SCREEN=csgo-clutch-#1
CSGO_START_MAP=de_dust2
CSGO_MAXPLAYERS=10

# SQLite — MUST match running srcds (bridge + kgns read this file)
WEAPONS_DB_PATH=/home/csgo/server/csgo/addons/sourcemod/data/sqlite/sourcemod-local.sq3
STICKERS_DB_PATH=/home/csgo/server/csgo/addons/sourcemod/data/sqlite/csgo_weaponstickers.sq3
WEAPONS_TABLE_PREFIX=
WS_ALLOWLIST_SOURCE=site-db

# Windows api-csgo + WSL CS: use UNC path instead:
# WEAPONS_DB_PATH=\\wsl$\Ubuntu\home\csgo\server\csgo\addons\sourcemod\data\sqlite\sourcemod-local.sq3
