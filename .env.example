PORT=3001
# Use 3001 if another user's process holds :3000 (no root). Then set site CSGO_API_URL to same port.
# PORT=3000

# Local scripts (test-gloves-sync, verify-api) use this; site uses CSGO_API_URL on Hostinger.
# CLUTCH_API_URL=http://127.0.0.1:3001
API_KEY=suachaveapi

# CORS — set to your public site URL (e.g. https://clutchclube.com.br)
SITE_ORIGIN=https://clutchclube.com.br

# Bind address (127.0.0.1 = only local; site on Hostinger still reaches via public IP if firewall allows)
# BIND_HOST=127.0.0.1

# Skin sync from site (same value as site/.env CSGO_SKINS_SYNC_KEY)
CSGO_SKINS_SYNC_KEY=clutch-dev-skins-sync-2026

# CS server root (used to auto-find weapons DB if WEAPONS_DB_PATH is wrong)
CSGO_SERVER_DIR=/home/csgo/server

# kgns weapons uses SourceMod storage-local → sourcemod-local.sq3 (NOT local.sq3)
WEAPONS_DB_PATH=/home/csgo/server/csgo/addons/sourcemod/data/sqlite/sourcemod-local.sq3
WEAPONS_TABLE_PREFIX=

# kgns !ws skin lists — default source is GitHub (no VPS config files)
WS_WEAPONS_LANG=english
# github | vps-config | all
WS_ALLOWLIST_SOURCE=github

# Site URL for bulk sync-from-site (Postgres → api → SQLite)
CLUTCH_SITE_URL=https://clutchclube.com.br

# RCON — triggers sm_clutch_applyskins after DB update
CSGO_SERVER_HOST=127.0.0.1
CSGO_RCON_PORT=27015
CSGO_RCON_PASSWORD=clutchclube

# srcds boot (scripts/start-csgo-screen.sh)
# CSGO_SERVER_DIR=/home/csgo/server
# CSGO_GSLT_TOKEN=your_steam_game_server_login_token
# CSGO_START_MAP=de_dust2

# Fallback when RCON refuses (hibernating srcds): screen session suffix
CLUTCH_CS_SCREEN=csgo-clutch-#1

# Optional: persist servers/matches
# DATA_DIR=./data
