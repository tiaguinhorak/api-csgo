PORT=3000
API_KEY=suachaveapi

# Skin sync from site (same value as site/.env CSGO_SKINS_SYNC_KEY)
CSGO_SKINS_SYNC_KEY=clutch-dev-skins-sync-2026

# CS server root (used to auto-find weapons DB if WEAPONS_DB_PATH is wrong)
CSGO_SERVER_DIR=/home/csgo/server

# kgns weapons uses SourceMod storage-local → sourcemod-local.sq3 (NOT local.sq3)
WEAPONS_DB_PATH=/home/csgo/server/csgo/addons/sourcemod/data/sqlite/sourcemod-local.sq3
WEAPONS_TABLE_PREFIX=

# kgns !ws skin lists (weapons_english.cfg + optional gloves_english.cfg)
WS_WEAPONS_LANG=english

# RCON — triggers sm_clutch_applyskins after DB update
CSGO_SERVER_HOST=127.0.0.1
CSGO_RCON_PORT=27015
CSGO_RCON_PASSWORD=clutchclube

# Fallback when RCON refuses (hibernating srcds): screen session suffix
CLUTCH_CS_SCREEN=csgo-clutch-#1

# Optional: persist servers/matches
# DATA_DIR=./data
