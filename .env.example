# =============================================================================
# Clutch VPS — unified config (one .env per game server machine)
# Copy to .env, edit, then: ./install.sh  (first time)  or  ./deploy.sh
# =============================================================================

# --- What changes per server (salas) ---
# ranked     = fila 5v5, match tracker, defer skins until match end
# warmup     = hub de modos públicos
# deathmatch | surf | retake | kz | casual | dm | ... = same stack as warmup
SERVER_PROFILE=ranked
SERVER_NAME="Clutch ranked #1"
SERVER_MODE_LABEL=Competitivo
CSGO_SERVER_POOL=ranked

# Examples for other VPS:
# SERVER_PROFILE=deathmatch
# SERVER_NAME="DM São Paulo #1"
# SERVER_MODE_LABEL=Deathmatch
# CSGO_SERVER_POOL=warmup
# CLUTCH_CS_SCREEN=csgo-dm-#1

PORT=3001
DATA_DIR=./data
BIND_HOST=0.0.0.0

# --- Shared secrets (same on EVERY VPS + site) ---
CSGO_SKINS_SYNC_KEY=clutch-dev-skins-sync-2026
API_KEY=suachaveapi
CLUTCH_SITE_URL=https://clutchclube.com.br
SITE_ORIGIN=https://clutchclube.com.br
# VPS sem DNS público: IP do site (Hostinger/Vercel)
# CLUTCH_SITE_RESOLVE_IP=76.76.21.21
# LAN dev (site npm run dev on PC — VPS cannot reach this; use push-stickers-dev-to-vps.sh)
# CLUTCH_SITE_FALLBACK_URL=http://192.168.100.6:3000
# CLUTCH_DEV_SITE_URL=http://127.0.0.1:3000
# On dev PC api-csgo .env: CSGO_API_URL=http://RANKED_PUBLIC_IP:3001

# --- CS:GO srcds (this machine) ---
CSGO_SERVER_DIR=/home/csgo/server
STEAMCMD_DIR=/home/csgo/steamcmd
# CSGO_AUTO_START=1   # install.sh starts screen after deploy (or use --start-game)
CSGO_SERVER_HOST=127.0.0.1
CSGO_PUBLIC_HOST=
# api-csgo e srcds na mesma VPS: gerencia screen/RCON via 127.0.0.1 mesmo registrando IP público (padrão).
# CSGO_SAME_MACHINE=0
CSGO_RCON_PORT=27015
CSGO_RCON_PASSWORD=clutchclube
CSGO_RCON_LOOPBACK=1
CLUTCH_CS_SCREEN=csgo-clutch-#1
CSGO_GSLT_TOKEN=
CSGO_START_MAP=de_dust2
CSGO_MAXPLAYERS=10
CSGO_GAME_TYPE=0
CSGO_GAME_MODE=1
CSGO_BIND_IP=0.0.0.0

# Public profiles: WARMUP_VPS=1 set automatically by ensure-profile-env.sh

# --- Skins SQLite (auto if CSGO_SERVER_DIR correct) ---
WEAPONS_DB_PATH=/home/csgo/server/csgo/addons/sourcemod/data/sqlite/sourcemod-local.sq3
STICKERS_DB_PATH=/home/csgo/server/csgo/addons/sourcemod/data/sqlite/csgo_weaponstickers.sq3
WEAPONS_TABLE_PREFIX=
WS_WEAPONS_LANG=english
WS_ALLOWLIST_SOURCE=site-db

# --- Site multi-server push (on Hostinger site/.env, not this file) ---
# CSGO_API_URL=http://ranked-ip:3001
# CSGO_WARMUP_API_URL=http://warmup-ip:3001
# CSGO_API_URLS=http://dm-vps:3001,http://surf-vps:3001
